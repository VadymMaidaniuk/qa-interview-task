TEST_ENV=dev

# The public demo app has one shared deployment. The separate variables keep
# the framework ready for real dev/staging/prod URLs without code changes.
DEV_BASE_URL=https://thinking-tester-contact-list.herokuapp.com
DEV_API_BASE_URL=https://thinking-tester-contact-list.herokuapp.com

STAGING_BASE_URL=https://thinking-tester-contact-list.herokuapp.com
STAGING_API_BASE_URL=https://thinking-tester-contact-list.herokuapp.com

PROD_BASE_URL=https://thinking-tester-contact-list.herokuapp.com
PROD_API_BASE_URL=https://thinking-tester-contact-list.herokuapp.com

# Public demo infrastructure can have occasional cold starts, so this threshold
# is intentionally tolerant while still detecting very slow responses.
MAX_API_RESPONSE_TIME_MS=10000
